generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGEMENT
  DEPARTMENT_HEAD
  PROJECT_MANAGER
  TEAM_MEMBER
  VIEW_ONLY
}

enum MeetingStatus {
  DRAFT
  FINALIZED
}

enum MeetingType {
  INTERNAL_MANAGEMENT
  CLIENT
  PROJECT
  SALES
  FINANCE
  HR
  DELIVERY
  STRATEGIC_PLANNING
  ISSUE_RESOLUTION
}

enum DecisionStatus {
  PROPOSED
  APPROVED
  REJECTED
  ON_HOLD
  REVERSED
  SUPERSEDED
}

enum ActionPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ActionStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  BLOCKED
  CANCELLED
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  FINALIZE
  LOGIN
  UPLOAD
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  password     String
  fullName     String    @map("full_name")
  role         Role      @default(TEAM_MEMBER)
  divisionId   String?   @map("division_id")
  departmentId String?   @map("department_id")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  division   Division?   @relation(fields: [divisionId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])

  ownedMeetings       Meeting[]              @relation("MeetingOwner")
  meetingAttendees    MeetingAttendee[]
  meetingAbsentees    MeetingAbsentee[]
  ownedDecisions      Decision[]             @relation("DecisionOwner")
  approvedDecisions   Decision[]             @relation("DecisionApprover")
  assignedActions     ActionItem[]           @relation("ActionAssignee")
  createdMeetings     Meeting[]              @relation("MeetingCreator")
  updatedMeetings     Meeting[]              @relation("MeetingUpdater")
  finalizedMeetings   Meeting[]              @relation("MeetingFinalizer")
  createdDecisions    Decision[]             @relation("DecisionCreator")
  updatedDecisions    Decision[]             @relation("DecisionUpdater")
  createdActions      ActionItem[]           @relation("ActionCreator")
  updatedActions      ActionItem[]           @relation("ActionUpdater")
  decisionStatusChanges DecisionStatusHistory[]
  auditLogs           AuditLog[]

  accounts Account[]
  sessions Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Division {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  departments Department[]
  users       User[]
  meetings    Meeting[]
  decisions   Decision[]

  @@map("divisions")
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  divisionId  String   @map("division_id")
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  division  Division   @relation(fields: [divisionId], references: [id])
  users     User[]
  meetings  Meeting[]
  decisions Decision[]

  @@map("departments")
}

model Client {
  id            String   @id @default(cuid())
  name          String
  contactPerson String?  @map("contact_person")
  email         String?
  phone         String?
  notes         String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  projects  Project[]
  meetings  Meeting[]
  decisions Decision[]

  @@map("clients")
}

model Project {
  id          String        @id @default(cuid())
  name        String
  clientId    String?       @map("client_id")
  clientName  String?       @map("client_name")
  description String?       @db.Text
  status      ProjectStatus @default(ACTIVE)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  client    Client?    @relation(fields: [clientId], references: [id])
  meetings  Meeting[]
  decisions Decision[]
  actions   ActionItem[]

  @@map("projects")
}

model Meeting {
  id                  String        @id @default(cuid())
  title               String
  meetingType         MeetingType   @map("meeting_type")
  date                DateTime      @db.Date
  time                String?
  location            String?
  onlineMeetingLink   String?       @map("online_meeting_link")
  divisionId          String?       @map("division_id")
  departmentId        String?       @map("department_id")
  projectId           String?       @map("project_id")
  clientId            String?       @map("client_id")
  ownerId             String        @map("owner_id")
  agenda              String?       @db.Text
  discussionSummary   String?       @map("discussion_summary") @db.Text
  keyDiscussionPoints String?       @map("key_discussion_points") @db.Text
  importantNotes      String?       @map("important_notes") @db.Text
  concernsRaised      String?       @map("concerns_raised") @db.Text
  risksIdentified     String?       @map("risks_identified") @db.Text
  status              MeetingStatus @default(DRAFT)
  createdById         String        @map("created_by_id")
  updatedById         String?       @map("updated_by_id")
  finalizedById       String?       @map("finalized_by_id")
  finalizedAt         DateTime?     @map("finalized_at")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  division    Division?           @relation(fields: [divisionId], references: [id])
  department  Department?         @relation(fields: [departmentId], references: [id])
  project     Project?            @relation(fields: [projectId], references: [id])
  client      Client?             @relation(fields: [clientId], references: [id])
  owner       User                @relation("MeetingOwner", fields: [ownerId], references: [id])
  createdBy   User                @relation("MeetingCreator", fields: [createdById], references: [id])
  updatedBy   User?               @relation("MeetingUpdater", fields: [updatedById], references: [id])
  finalizedBy User?               @relation("MeetingFinalizer", fields: [finalizedById], references: [id])
  attendees   MeetingAttendee[]
  absentees   MeetingAbsentee[]
  attachments MeetingAttachment[]
  decisions   Decision[]
  actions     ActionItem[]

  @@map("meetings")
}

model MeetingAttendee {
  id        String   @id @default(cuid())
  meetingId String   @map("meeting_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([meetingId, userId])
  @@map("meeting_attendees")
}

model MeetingAbsentee {
  id        String   @id @default(cuid())
  meetingId String   @map("meeting_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([meetingId, userId])
  @@map("meeting_absentees")
}

model MeetingAttachment {
  id           String   @id @default(cuid())
  meetingId    String   @map("meeting_id")
  fileName     String   @map("file_name")
  fileUrl      String   @map("file_url")
  fileType     String   @map("file_type")
  fileSize     Int      @map("file_size")
  storagePath  String   @map("storage_path")
  uploadedById String?  @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("meeting_attachments")
}

model Decision {
  id            String         @id @default(cuid())
  title         String
  description   String         @db.Text
  meetingId     String?        @map("meeting_id")
  divisionId    String?        @map("division_id")
  departmentId  String?        @map("department_id")
  projectId     String?        @map("project_id")
  clientId      String?        @map("client_id")
  ownerId       String         @map("owner_id")
  approvedById  String?        @map("approved_by_id")
  dateDecided   DateTime       @map("date_decided") @db.Date
  impactArea    String?        @map("impact_area")
  status        DecisionStatus @default(PROPOSED)
  remarks       String?        @db.Text
  createdById   String         @map("created_by_id")
  updatedById   String?        @map("updated_by_id")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  meeting       Meeting?                @relation(fields: [meetingId], references: [id])
  division      Division?               @relation(fields: [divisionId], references: [id])
  department    Department?             @relation(fields: [departmentId], references: [id])
  project       Project?                @relation(fields: [projectId], references: [id])
  client        Client?                 @relation(fields: [clientId], references: [id])
  owner         User                    @relation("DecisionOwner", fields: [ownerId], references: [id])
  approvedBy    User?                   @relation("DecisionApprover", fields: [approvedById], references: [id])
  createdBy     User                    @relation("DecisionCreator", fields: [createdById], references: [id])
  updatedBy     User?                   @relation("DecisionUpdater", fields: [updatedById], references: [id])
  statusHistory DecisionStatusHistory[]
  attachments   DecisionAttachment[]
  actions       ActionItem[]

  @@map("decisions")
}

model DecisionStatusHistory {
  id          String         @id @default(cuid())
  decisionId  String         @map("decision_id")
  fromStatus  DecisionStatus? @map("from_status")
  toStatus    DecisionStatus @map("to_status")
  changedById String         @map("changed_by_id")
  remarks     String?        @db.Text
  createdAt   DateTime       @default(now()) @map("created_at")

  decision  Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  changedBy User     @relation(fields: [changedById], references: [id])

  @@map("decision_status_history")
}

model DecisionAttachment {
  id           String   @id @default(cuid())
  decisionId   String   @map("decision_id")
  fileName     String   @map("file_name")
  fileUrl      String   @map("file_url")
  fileType     String   @map("file_type")
  fileSize     Int      @map("file_size")
  storagePath  String   @map("storage_path")
  uploadedById String?  @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  decision Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  @@map("decision_attachments")
}

model ActionItem {
  id              String         @id @default(cuid())
  title           String
  description     String?        @db.Text
  assignedToId    String         @map("assigned_to_id")
  dueDate         DateTime       @map("due_date") @db.Date
  priority        ActionPriority @default(MEDIUM)
  status          ActionStatus   @default(NOT_STARTED)
  meetingId       String?        @map("meeting_id")
  decisionId      String?        @map("decision_id")
  projectId       String?        @map("project_id")
  completionNotes String?        @map("completion_notes") @db.Text
  createdById     String         @map("created_by_id")
  updatedById     String?        @map("updated_by_id")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  assignedTo User      @relation("ActionAssignee", fields: [assignedToId], references: [id])
  meeting    Meeting?  @relation(fields: [meetingId], references: [id])
  decision   Decision? @relation(fields: [decisionId], references: [id])
  project    Project?  @relation(fields: [projectId], references: [id])
  createdBy  User      @relation("ActionCreator", fields: [createdById], references: [id])
  updatedBy  User?     @relation("ActionUpdater", fields: [updatedById], references: [id])

  @@map("action_items")
}

model AuditLog {
  id         String      @id @default(cuid())
  entityType String      @map("entity_type")
  entityId   String      @map("entity_id")
  action     AuditAction
  userId     String?     @map("user_id")
  details    String?     @db.Text
  metadata   Json?
  createdAt  DateTime    @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}
